{
  "name": "systema",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "One offline-first PWA that runs an entire travel workflow — before, during and after a trip. Local-first, free to host, bring-your-own-Claude.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.13.2",
    "@vite-pwa/assets-generator": "^1.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "dexie": "^4.4.4",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5"
  }
}
